# =============================================================================
# Frontend (Vite) — exposed to the browser. Anon key is public-safe.
# =============================================================================
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_APP_BASE_URL="https://your-vercel-domain.vercel.app"

# =============================================================================
# Backend (Supabase Edge Functions) — set via `supabase secrets set` or the
# Supabase dashboard. NEVER expose these to the browser.
# =============================================================================

# Auto-provided by Supabase; included here for documentation / local dev.
# SUPABASE_URL="https://your-project-id.supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# OpenRouter — high-quality GPT-5.5 calls for chat, retrieval planning,
# verification, document analysis, pseudonymization, legal reports, title
# generation, context summaries, and embeddings.
OPENROUTER_API_KEY="your-openrouter-key"
OPENROUTER_MODEL_HIGH_QUALITY="openai/gpt-5.5"
OPENROUTER_EMBEDDING_MODEL="openai/text-embedding-3-small"

# App platform — used by Supabase Edge Function CORS and redirects.
APP_BASE_URL="https://your-vercel-domain.vercel.app"
CORS_ALLOWED_ORIGINS="https://your-vercel-domain.vercel.app,http://localhost:5173,http://localhost:8080"

# Firecrawl — web-scraping for FINDOK / EUR-Lex / CURIA / PARLAMENT / GII.
# Required by the retrieval function. Without it, those providers return
# zero results and the chat has weaker source coverage.
FIRECRAWL_API_KEY="your-firecrawl-api-key"
